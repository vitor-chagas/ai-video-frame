# ── Shared (same in both environments) ──────────────────────────────────────
# Google OAuth issuer (always the same)
AUTH_ISSUER_URL=https://accounts.google.com
# Resend email
RESEND_API_KEY=re_...
# RapidAPI - get from your RapidAPI dashboard
RAPIDAPI_PROXY_SECRET=your_rapidapi_proxy_secret_here
# OpenAI (Whisper transcription and subtitle translation)
OPENAI_API_KEY=sk-...
# PostHog Analytics (public key, safe to expose in frontend)
VITE_POSTHOG_API_KEY=phc_...

# ── Development ───────────────────────────────────────────────────────────────
# Switching between dev/prod is automatic: npm run dev → DEV_*, npm run start → PROD_*
DEV_DATABASE_URL=postgresql://user:password@host:port/dbname?pgbouncer=true
DEV_SESSION_SECRET=your_dev_session_secret_here
DEV_SUPABASE_URL=https://your-dev-project-id.supabase.co
DEV_SUPABASE_PUB_KEY=your_dev_supabase_pub_key
DEV_STRIPE_SECRET_KEY=sk_test_...
DEV_STRIPE_PUBLISHABLE_KEY=pk_test_...
DEV_STRIPE_PRICE_SINGLE=price_test_...
DEV_STRIPE_PRICE_MONTHLY=price_test_...
DEV_STRIPE_PRICE_YEARLY=price_test_...
DEV_STRIPE_WEBHOOK_SECRET=whsec_test_...
DEV_AUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
DEV_AUTH_CLIENT_SECRET=your_client_secret
DEV_AUTH_CALLBACK_URL=http://localhost:5002/api/callback
DEV_AUTH_LOGOUT_REDIRECT_URL=http://localhost:5002
DEV_PORT=5002

# ── Production ────────────────────────────────────────────────────────────────
PROD_DATABASE_URL=postgresql://user:password@host:port/dbname?pgbouncer=true
PROD_SESSION_SECRET=your_prod_session_secret_here
PROD_SUPABASE_URL=https://your-prod-project-id.supabase.co
PROD_SUPABASE_PUB_KEY=your_prod_supabase_pub_key
PROD_STRIPE_SECRET_KEY=sk_live_...
PROD_STRIPE_PUBLISHABLE_KEY=pk_live_...
PROD_STRIPE_PRICE_SINGLE=price_...
PROD_STRIPE_PRICE_MONTHLY=price_...
PROD_STRIPE_PRICE_YEARLY=price_...
PROD_STRIPE_WEBHOOK_SECRET=whsec_...
PROD_AUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
PROD_AUTH_CLIENT_SECRET=your_client_secret
PROD_AUTH_CALLBACK_URL=https://yourdomain.com/api/callback
PROD_AUTH_LOGOUT_REDIRECT_URL=https://yourdomain.com
PROD_PORT=5002
