# Database Configuration
DATABASE_URL=postgresql://user:password@host:port/dbname?pgbouncer=true
SESSION_SECRET=your_session_secret_here

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUB_KEY=your_supabase_pub_key

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_SINGLE=price_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google OAuth Configuration
AUTH_ISSUER_URL=https://accounts.google.com
AUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
AUTH_CLIENT_SECRET=your_client_secret
AUTH_CALLBACK_URL=http://localhost:5001/api/callback
AUTH_LOGOUT_REDIRECT_URL=http://localhost:5001
PORT=5001

# Resend Email Configuration
RESEND_API_KEY=re_...

# RapidAPI Configuration
# Get this from your RapidAPI dashboard after creating your API listing
RAPIDAPI_PROXY_SECRET=your_rapidapi_proxy_secret_here

# PostHog Analytics (public key, safe to expose in frontend)
VITE_POSTHOG_API_KEY=phc_...
